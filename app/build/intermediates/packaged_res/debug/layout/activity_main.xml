<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0F0F19">

    <com.russianblocks.game.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Start screen overlay -->
    <LinearLayout
        android:id="@+id/startOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD0F0F19"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle"
            android:textColor="#8888AA"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:backgroundTint="#FF6200EE"
            android:text="@string/play"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/controls_hint"
            android:textColor="#666680"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Pause button floats bottom-right -->
    <Button
        android:id="@+id/btnPause"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:backgroundTint="#44FFFFFF"
        android:minWidth="80dp"
        android:text="@string/pause"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>
