<?xml version="1.0" encoding="utf-8"?>
<!-- Dark theme: night sky + moon + stars -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="#151B3D"
                android:endColor="#030712"
                android:startColor="#0F172A"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:height="200dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#40050812"
                android:endColor="#90050812"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="top|end"
        android:right="8dp"
        android:top="36dp">
        <shape android:shape="oval">
            <solid android:color="#223B82F6" />
        </shape>
    </item>
