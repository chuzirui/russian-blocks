<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <LinearLayout
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@color/ds_surface_dark"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.russianblocks.game.GameView
                android:id="@+id/gameView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Positioned in code below NEXT + stats (same column width as HUD) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBomb"
                style="@style/Widget.RussianBlocks.Button.Control"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:minHeight="@dimen/bomb_button_min_height"
                android:paddingHorizontal="12dp"
                android:paddingTop="@dimen/bomb_button_padding_v"
                android:paddingBottom="@dimen/bomb_button_padding_v"
                android:contentDescription="@string/desc_bomb"
                android:gravity="center"
                android:text="@string/bomb_label"
                android:textColor="@color/btn_bomb_content"
                android:textSize="14sp"
                android:visibility="gone"
                android:enabled="false"
                app:icon="@drawable/ic_control_bomb"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="24dp"
                app:iconTint="@color/btn_bomb_content" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/controlsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_controls_bar"
            android:paddingStart="@dimen/control_bar_padding_h"
            android:paddingEnd="@dimen/control_bar_padding_h"
            android:paddingTop="@dimen/control_bar_padding_top"
            android:paddingBottom="@dimen/control_bar_padding_bottom"
            android:visibility="gone">

            <!-- Row 1: three equal picture keys (move / rotate / move) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnLeft"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/control_button_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/control_button_gap"
                    android:background="@drawable/btn_key_neutral"
                    android:contentDescription="@string/desc_move_left"
                    android:focusable="true"
                    android:padding="@dimen/control_icon_padding"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_control_chevron_left"
                    app:tint="@color/ds_control_icon" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnRotate"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/control_button_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/control_button_gap"
                    android:background="@drawable/btn_key_accent"
                    android:contentDescription="@string/desc_rotate"
                    android:focusable="true"
                    android:padding="@dimen/control_icon_padding"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_control_rotate_cw"
                    app:tint="@color/white" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnRight"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/control_button_height"
                    android:layout_weight="1"
                    android:background="@drawable/btn_key_neutral"
                    android:contentDescription="@string/desc_move_right"
                    android:focusable="true"
                    android:padding="@dimen/control_icon_padding"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_control_chevron_right"
                    app:tint="@color/ds_control_icon" />
            </LinearLayout>

            <!-- Row 2: soft drop + hard drop (wider CTA key) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/control_bar_row_gap"
                android:gravity="center"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnDown"
                    android:layout_width="@dimen/control_soft_min_width"
                    android:layout_height="@dimen/control_button_height"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_key_neutral"
                    android:contentDescription="@string/desc_soft_drop"
                    android:focusable="true"
                    android:padding="@dimen/control_icon_padding"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_control_chevron_down"
                    app:tint="@color/ds_control_icon" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnDrop"
                    android:layout_width="@dimen/control_drop_min_width"
                    android:layout_height="@dimen/control_button_height"
                    android:background="@drawable/btn_key_cta"
                    android:contentDescription="@string/desc_hard_drop"
                    android:focusable="true"
                    android:padding="@dimen/control_icon_padding"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_control_hard_drop"
                    app:tint="@color/white" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/startOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop"
            android:src="@drawable/start_menu_illustration" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ds_overlay_scrim" />

        <LinearLayout
            android:id="@+id/startMenuContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:maxWidth="340dp"
                android:background="@drawable/glass_surface"
                android:elevation="12dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="36dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.04"
                    android:text="@string/app_name"
                    android:textColor="@color/ds_text"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.01"
                    android:lineSpacingMultiplier="1.15"
                    android:text="@string/subtitle"
                    android:textColor="@color/ds_text_muted"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    style="@style/Widget.RussianBlocks.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:contentDescription="@string/desc_play"
                    android:text="@string/play" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/controls_hint"
                    android:textColor="@color/ds_text_muted"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShop"
                    style="@style/Widget.RussianBlocks.Button.Shop"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="22dp"
                    android:minWidth="176dp"
                    android:contentDescription="@string/desc_bomb_shop"
                    android:text="@string/bomb_shop" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
