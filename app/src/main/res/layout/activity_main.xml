<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@color/ds_surface_dark"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111"
            android:visibility="gone" />

        <com.russianblocks.game.GameView
            android:id="@+id/gameView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/controlsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_controls_bar"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLeft"
                        style="@style/Widget.RussianBlocks.Button.Control"
                        android:layout_width="wrap_content"
                        android:layout_height="58dp"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="56dp"
                        android:paddingHorizontal="14dp"
                        android:contentDescription="@string/desc_move_left"
                        android:text=""
                        app:icon="@drawable/ic_control_chevron_left"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="28dp"
                        app:iconTint="@color/ds_control_icon" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRotate"
                        style="@style/Widget.RussianBlocks.Button.ControlAccent"
                        android:layout_width="wrap_content"
                        android:layout_height="58dp"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="56dp"
                        android:paddingHorizontal="14dp"
                        android:contentDescription="@string/desc_rotate"
                        android:text=""
                        app:icon="@drawable/ic_control_rotate_cw"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="28dp"
                        app:iconTint="@color/white" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRight"
                        style="@style/Widget.RussianBlocks.Button.Control"
                        android:layout_width="wrap_content"
                        android:layout_height="58dp"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="56dp"
                        android:paddingHorizontal="14dp"
                        android:contentDescription="@string/desc_move_right"
                        android:text=""
                        app:icon="@drawable/ic_control_chevron_right"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="28dp"
                        app:iconTint="@color/ds_control_icon" />
                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDown"
                        style="@style/Widget.RussianBlocks.Button.Control"
                        android:layout_width="wrap_content"
                        android:layout_height="58dp"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="56dp"
                        android:paddingHorizontal="14dp"
                        android:contentDescription="@string/desc_soft_drop"
                        android:text=""
                        app:icon="@drawable/ic_control_chevron_down"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="28dp"
                        app:iconTint="@color/ds_control_icon" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDrop"
                        style="@style/Widget.RussianBlocks.Button.Cta"
                        android:layout_width="wrap_content"
                        android:layout_height="72dp"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="88dp"
                        android:paddingHorizontal="20dp"
                        android:contentDescription="@string/desc_hard_drop"
                        android:text=""
                        app:icon="@drawable/ic_control_hard_drop"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="32dp"
                        app:iconTint="@color/white" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBomb"
                        style="@style/Widget.RussianBlocks.Button.Control"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:contentDescription="@string/desc_bomb"
                        android:gravity="center"
                        android:text="@string/bomb_label"
                        android:textColor="@color/btn_bomb_content"
                        android:textSize="13sp"
                        android:enabled="false"
                        app:icon="@drawable/ic_control_bomb"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="20dp"
                        app:iconTint="@color/btn_bomb_content" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/startOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/splash_bg" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#590F172A" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:maxWidth="360dp"
                android:background="@drawable/glass_surface"
                android:elevation="8dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="32dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:letterSpacing="0.02"
                    android:text="@string/app_name"
                    android:textColor="@color/ds_text"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="@string/subtitle"
                    android:textColor="@color/ds_text_muted"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    style="@style/Widget.RussianBlocks.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:contentDescription="@string/desc_play"
                    android:text="@string/play" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/controls_hint"
                    android:textColor="@color/ds_text_muted"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShop"
                    style="@style/Widget.RussianBlocks.Button.Shop"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:minWidth="168dp"
                    android:contentDescription="@string/desc_bomb_shop"
                    android:text="@string/bomb_shop" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
