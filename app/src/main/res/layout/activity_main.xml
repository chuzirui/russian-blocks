<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0F0F19">

    <LinearLayout
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Banner ad at top -->
        <com.google.android.gms.ads.AdView
            android:id="@+id/adBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="#FF0A0A14"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-3940256099942544/6300978111"
            android:visibility="gone" />

        <com.russianblocks.game.GameView
            android:id="@+id/gameView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Control buttons -->
        <LinearLayout
            android:id="@+id/controlsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF0A0A14"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <!-- Row 1: Left / Rotate / Right -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnLeft"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF2A2A40"
                    android:text="◀"
                    android:textColor="#DDDDDD"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/btnRotate"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:backgroundTint="#FF3A2A60"
                    android:text="↻"
                    android:textColor="#DDDDDD"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/btnRight"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#FF2A2A40"
                    android:text="▶"
                    android:textColor="#DDDDDD"
                    android:textSize="22sp" />

            </LinearLayout>

            <!-- Row 2: Down / Drop / Pause -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnDown"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF2A2A40"
                    android:text="▼"
                    android:textColor="#DDDDDD"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/btnDrop"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:backgroundTint="#FF6200EE"
                    android:text="⏬"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btnBomb"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:backgroundTint="#FF331111"
                    android:text="💣"
                    android:textColor="#666666"
                    android:textSize="20sp"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnPause"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#FF1A1A30"
                    android:text="@string/pause"
                    android:textColor="#999999"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Start screen overlay -->
    <LinearLayout
        android:id="@+id/startOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD0F0F19"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle"
            android:textColor="#8888AA"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:backgroundTint="#FF6200EE"
            android:text="@string/play"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/controls_hint"
            android:textColor="#666680"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnShop"
            android:layout_width="160dp"
            android:layout_height="42dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#FF2A2A40"
            android:text="🛒 Bomb Shop"
            android:textColor="#AAAACC"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
